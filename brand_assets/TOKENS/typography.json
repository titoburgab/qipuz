{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "QIPUZ Typography Tokens",
    "version": "2.0.0",
    "updated": "2026-06-01",
    "reference": "BRAND_BOOK/Typography.md"
  },
  "font": {
    "family": {
      "primary": {
        "$value": "\"Söhne\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
        "$type": "fontFamily",
        "$description": "Primary brand typeface. Requires commercial license from Klim Type Foundry."
      },
      "secondary": {
        "$value": "\"Inter\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
        "$type": "fontFamily",
        "$description": "Secondary typeface for UI, data, and dense functional contexts."
      },
      "mono": {
        "$value": "\"IBM Plex Mono\", \"Fira Code\", \"Cascadia Code\", monospace",
        "$type": "fontFamily",
        "$description": "Monospace typeface for code blocks and technical strings."
      }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "display-xl": { "$value": "72px", "$type": "fontSize", "$description": "Hero headlines — Söhne Light" },
      "display-lg": { "$value": "56px", "$type": "fontSize", "$description": "Section headlines — Söhne Light" },
      "display-md": { "$value": "40px", "$type": "fontSize", "$description": "Sub-section headers — Söhne Regular" },
      "heading-lg": { "$value": "32px", "$type": "fontSize", "$description": "H1 — Söhne Medium" },
      "heading-md": { "$value": "24px", "$type": "fontSize", "$description": "H2 — Söhne Medium" },
      "heading-sm": { "$value": "20px", "$type": "fontSize", "$description": "H3 — Söhne Medium" },
      "body-lg": { "$value": "18px", "$type": "fontSize", "$description": "Lead paragraph — Söhne Regular" },
      "body-md": { "$value": "16px", "$type": "fontSize", "$description": "Default body text — Söhne Regular" },
      "body-sm": { "$value": "14px", "$type": "fontSize", "$description": "Secondary text, captions — Inter Regular" },
      "label": { "$value": "12px", "$type": "fontSize", "$description": "Labels, tags, metadata — Inter Medium" },
      "code": { "$value": "14px", "$type": "fontSize", "$description": "Code blocks — IBM Plex Mono" }
    },
    "lineHeight": {
      "tight": { "$value": 1.05, "$type": "lineHeight", "$description": "Display XL" },
      "display": { "$value": 1.1, "$type": "lineHeight", "$description": "Display LG" },
      "heading": { "$value": 1.2, "$type": "lineHeight", "$description": "Headings" },
      "body": { "$value": 1.65, "$type": "lineHeight", "$description": "Body text default" },
      "relaxed": { "$value": 1.7, "$type": "lineHeight", "$description": "Long-form body" },
      "label": { "$value": 1.4, "$type": "lineHeight", "$description": "Labels and captions" }
    },
    "letterSpacing": {
      "display": { "$value": "-0.02em", "$type": "letterSpacing", "$description": "Display sizes" },
      "heading": { "$value": "-0.01em", "$type": "letterSpacing", "$description": "Heading sizes" },
      "body": { "$value": "0", "$type": "letterSpacing", "$description": "Body text" },
      "label": { "$value": "0.08em", "$type": "letterSpacing", "$description": "Labels" },
      "caps": { "$value": "0.12em", "$type": "letterSpacing", "$description": "All-caps labels" }
    }
  }
}
