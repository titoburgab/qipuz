{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "QIPUZ Breakpoint Tokens",
    "version": "2.0.0",
    "updated": "2026-06-01",
    "reference": "DESIGN_SYSTEM/Breakpoints.md"
  },
  "breakpoint": {
    "xs": {
      "$value": "375px",
      "$type": "dimension",
      "$description": "Minimum supported mobile width (iPhone SE)"
    },
    "sm": {
      "$value": "640px",
      "$type": "dimension",
      "$description": "Large mobile / small tablet"
    },
    "md": {
      "$value": "768px",
      "$type": "dimension",
      "$description": "Tablet portrait"
    },
    "lg": {
      "$value": "1024px",
      "$type": "dimension",
      "$description": "Tablet landscape / small desktop"
    },
    "xl": {
      "$value": "1280px",
      "$type": "dimension",
      "$description": "Standard desktop"
    },
    "2xl": {
      "$value": "1536px",
      "$type": "dimension",
      "$description": "Large desktop"
    }
  },
  "grid": {
    "columns-mobile": { "$value": 4, "$type": "number" },
    "columns-tablet": { "$value": 8, "$type": "number" },
    "columns-desktop": { "$value": 12, "$type": "number" },
    "gutter-mobile": { "$value": "16px", "$type": "dimension" },
    "gutter-tablet": { "$value": "24px", "$type": "dimension" },
    "gutter-desktop": { "$value": "32px", "$type": "dimension" },
    "margin-mobile": { "$value": "20px", "$type": "dimension" },
    "margin-tablet": { "$value": "40px", "$type": "dimension" },
    "margin-desktop": { "$value": "80px", "$type": "dimension" },
    "max-width": { "$value": "1200px", "$type": "dimension" }
  }
}
